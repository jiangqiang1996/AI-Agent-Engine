{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code Review Findings",
  "description": "代码审查子代理的结构化输出 schema",
  "type": "object",
  "required": ["reviewer", "findings", "residual_risks"],
  "properties": {
    "reviewer": {
      "type": "string",
      "description": "产生此输出的人设名称（例如 'correctness'、'security'）"
    },
    "findings": {
      "type": "array",
      "description": "代码审查发现列表。未发现问题时为空数组。",
      "items": {
        "type": "object",
        "required": [
          "title",
          "severity",
          "file",
          "line",
          "why_it_matters",
          "autofix_class",
          "owner",
          "requires_verification",
          "confidence",
          "evidence",
          "pre_existing"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "简短、具体的问题标题，10个词以内。",
            "maxLength": 100
          },
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"],
            "description": "问题严重程度级别"
          },
          "file": {
            "type": "string",
            "description": "相对于仓库根目录的文件路径"
          },
          "line": {
            "type": "integer",
            "description": "问题的主要行号",
            "minimum": 1
          },
          "why_it_matters": {
            "type": "string",
            "description": "影响和故障模式——不是'哪里错了'，而是'什么会出问题'"
          },
          "autofix_class": {
            "type": "string",
            "enum": ["safe_auto", "gated_auto", "manual", "advisory"],
            "description": "审查者对综合后该问题处理方式的保守建议"
          },
          "owner": {
            "type": "string",
            "enum": ["review-fixer", "downstream-resolver", "human", "release"],
            "description": "综合后应负责该发现后续行动的角色"
          },
          "requires_verification": {
            "type": "boolean",
            "description": "此发现的修复是否需要通过针对性测试或后续审查重新验证"
          },
          "suggested_fix": {
            "type": ["string", "null"],
            "description": "具体的最小修复方案。如果没有明显的好方案则省略。"
          },
          "confidence": {
            "type": "number",
            "description": "审查者对此发现的置信度",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "evidence": {
            "type": "array",
            "description": "基于代码的证据。至少1项。",
            "items": { "type": "string" },
            "minItems": 1
          },
          "pre_existing": {
            "type": "boolean",
            "description": "如果此问题存在于与当前 diff 无关的未变更代码中则为 true"
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "description": "审查者注意到但无法确认为发现的风险",
      "items": { "type": "string" }
    },
    "testing_gaps": {
      "type": "array",
      "description": "审查者识别到的缺失测试覆盖",
      "items": { "type": "string" }
    }
  },
  "_meta": {
    "confidence_thresholds": {
      "suppress": "低于 0.60——不报告。例外：0.50+ 的 P0。",
      "flag": "0.60-0.69——仅在明确可操作时包含。",
      "confident": "0.70-0.84——附完整证据报告。",
      "certain": "0.85-1.00——仅从代码验证。"
    },
    "autofix_classes": {
      "safe_auto": "局部的、确定性的修复。示例：提取辅助函数、添加空值检查、修复差一错误。",
      "gated_auto": "存在修复但会更改契约或权限。示例：添加认证、更改 API 响应结构。",
      "manual": "需要设计决策或跨模块变更。示例：重新设计数据模型。",
      "advisory": "信息性事项。示例：残余风险说明、部署注意事项。"
    },
    "return_tiers": {
      "merge_tier": "返回给编排器：title、severity、file、line、confidence、autofix_class、owner、requires_verification、pre_existing、suggested_fix。",
      "detail_tier": "产物文件中必填：why_it_matters、evidence。"
    }
  }
}
